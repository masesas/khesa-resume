		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 5px;
	}
	.wi__title {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(18px, 2.4vw, 24px);
		letter-spacing: -0.01em;
		line-height: 1.15;
		display: inline-flex;
		align-items: baseline;
		gap: 8px;
	}
	.wi__row--featured .wi__title {
		font-size: clamp(22px, 3.2vw, 34px);
