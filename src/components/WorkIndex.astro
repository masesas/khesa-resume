	.wi__wrapper-info {
		display: flex;
		gap: 15px;
		margin-top: 20px;
	}
	.wi__wrapper-sub {
		display: flex;
		gap: 20px;
		margin-top: 20px;
	}
	.wi__wrapper-col {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 10x;
	}
	.wi__lable-thin {
		font-family: var(--font-mono);
		font-size: 11px;
		color: #c4cae0;
	}
	.wi__seperator {
		margin-top: auto;
		margin-bottom: auto;
		width: 1px;
		height: 20px;
		background: var(--line);
	}

	/* ---------- Responsive: mobile = stacked image cards ----------
     No hover on touch, so the desktop preview pane is dropped and each row
     becomes a vertical card: a large framed hero shot on top, then the
     number, title, impact, platform badges and year below. */
	@media (max-width: 900px) {
		.wi {
			grid-template-columns: 1fr;
			gap: 0;
		}
		.wi__preview {
			display: none;
		}

		.wi__list {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
			gap: 18px;
		}
		.wi__row,
		.wi__row:last-child {
			border: none;
		}
		/* No dimming behavior on touch. */
		.wi__list:hover .wi__link,
		.wi__link {
			opacity: 1;
		}

		.wi__link {
			display: grid;
			grid-template-columns: auto 1fr auto;
			grid-template-areas:
				"thumb thumb thumb"
				"num   main  meta";
			column-gap: 14px;
			row-gap: 16px;
			align-items: start;
			padding: 14px;
			border: 1px solid var(--line-soft);
			border-radius: 16px;
			background: linear-gradient(
				180deg,
				var(--bg-card),
				color-mix(in srgb, var(--bg-card) 65%, var(--bg))
			);
			transition:
				border-color 0.3s ease,
				transform 0.3s ease;
		}
		.wi__link:active {
			transform: scale(0.99);
			border-color: color-mix(in srgb, var(--accent) 40%, transparent);
		}
		/* Cancel desktop hover-shift. */
		.wi__link:hover {
			padding-left: 14px;
		}

		/* Hero image: full-width framed shot. */
		.wi__thumb {
			grid-area: thumb;
			display: block;
			width: 100%;
			aspect-ratio: 16 / 10;
			border-radius: 10px;
			overflow: hidden;
			border: 1px solid var(--line-soft);
			background: var(--bg);
		}
		.wi__thumb img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			object-position: top center;
		}

		.wi__num {
			grid-area: num;
			padding-top: 2px;
		}
		.wi__main {
			grid-area: main;
		}
		.wi__title {
			font-size: 19px;
		}
		.wi__row--featured .wi__title {
			font-size: 21px;
		}

		/* Bring the meta column back (it was hidden on the desktop list). */
		.wi__meta {
			grid-area: meta;
			display: flex;
		}
	}

	/* Single column on the narrowest screens. */
	@media (max-width: 560px) {
		.wi__list {
			grid-template-columns: 1fr;
		}
		.wi__thumb {
			aspect-ratio: 16 / 9;
		}
	}
</style>

<script>
	const AUTOPLAY_MS = 3200;
	const reduceMotion = window.matchMedia(
		"(prefers-reduced-motion: reduce)",
	).matches;

	type Carousel = { reset: () => void; play: () => void; stop: () => void };

	// --- Carousel: prev/next/dots + autoplay per project, wraps around ---
	function setupCarousel(root: HTMLElement): Carousel | undefined {
		const track = root.querySelector<HTMLElement>(".wi__track");
		const slides = root.querySelectorAll<HTMLElement>(".wi__slide");
		const dots = root.querySelectorAll<HTMLElement>(".wi__dot");
		const total = slides.length;
		if (!track || total === 0) return;

		let timer: ReturnType<typeof setInterval> | null = null;
		let wantPlay = false; // this carousel's figure is the active one
		let hovering = false;

		const go = (next: number) => {
			const i = ((next % total) + total) % total; // wrap
			root.dataset.index = String(i);
			track.style.transform = `translateX(-${i * 100}%)`;
			dots.forEach((d, di) =>
				d.setAttribute("data-active", di === i ? "true" : "false"),
			);
		};

		const clear = () => {
			if (timer) {
				clearInterval(timer);
				timer = null;
			}
		};
		// Autoplay only when active, not hovered, motion allowed, and >1 slide.
		const refresh = () => {
			clear();
			if (wantPlay && !hovering && !reduceMotion && total > 1) {
				timer = setInterval(
					() => go(Number(root.dataset.index ?? 0) + 1),
					AUTOPLAY_MS,
				);
			}
		};

		// Manual interaction moves the slide and restarts the autoplay clock.
		const manual = (n: number) => {
			go(n);
			refresh();
		};
		root.querySelector("[data-prev]")?.addEventListener("click", () =>
			manual(Number(root.dataset.index ?? 0) - 1),
		);
		root.querySelector("[data-next]")?.addEventListener("click", () =>
			manual(Number(root.dataset.index ?? 0) + 1),
		);
		dots.forEach((dot, di) =>
			dot.addEventListener("click", () => manual(di)),
		);

		// Pause on hover so users can study a screenshot.
		root.addEventListener("pointerenter", () => {
			hovering = true;
			refresh();
		});
		root.addEventListener("pointerleave", () => {
			hovering = false;
			refresh();
		});

		return {
			reset: () => go(0),
			play: () => {
				wantPlay = true;
				refresh();
			},
			stop: () => {
				wantPlay = false;
				clear();
			},
		};
	}

	const carousels = new Map<HTMLElement, Carousel | undefined>();
	document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((c) => {
		carousels.set(c, setupCarousel(c));
	});

	// Start autoplay on whichever figure is active at load (the first project).
	function playActive() {
		document
			.querySelectorAll<HTMLElement>(
				'.wi__figure[data-active="true"] [data-carousel]',
			)
			.forEach((c) => carousels.get(c)?.play());
	}
	playActive();

	// Hover/focus a row -> activate the matching preview figure. Pointer-fine only
	// (touch keeps the inline thumbs and the default active figure).
	const fine = window.matchMedia(
		"(hover: hover) and (pointer: fine)",
	).matches;
	if (fine) {
		const rows = document.querySelectorAll<HTMLElement>(".wi__link");
		const figures = document.querySelectorAll<HTMLElement>(".wi__figure");

		function activate(slug: string) {
			rows.forEach((r) =>
				r.setAttribute(
					"data-active",
					r.dataset.slug === slug ? "true" : "false",
				),
			);
			figures.forEach((f) => {
				const isActive = f.dataset.preview === slug;
				f.setAttribute("data-active", isActive ? "true" : "false");
				const c = f.querySelector<HTMLElement>("[data-carousel]");
				const car = c ? carousels.get(c) : undefined;
				if (!car) return;
				if (isActive) {
					// Reset to first image, then (re)start autoplay for this project.
					car.reset();
					car.play();
				} else {
					car.stop();
				}
			});
		}

		rows.forEach((row) => {
			const slug = row.dataset.slug;
			if (!slug) return;
			row.addEventListener("pointerenter", () => activate(slug));
			row.addEventListener("focus", () => activate(slug));
		});
	}
</script>
