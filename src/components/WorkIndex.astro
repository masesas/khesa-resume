	.wi__link {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 18px;
		padding: 20px 6px;
		text-decoration: none;
		color: inherit;
		transition:
			padding-left 0.35s cubic-bezier(0.22, 1, 0.36, 1),
			opacity 0.3s ease;
	}
	.wi__row--featured .wi__link {
		padding-top: 28px;
		padding-bottom: 28px;
	}

	/* Dim the other rows when the list is hovered, spotlighting the active one. */
	.wi__list:hover .wi__link {
		opacity: 0.45;
	}
	.wi__list:hover .wi__link:hover,
	.wi__link[data-active="true"] {
		opacity: 1;
	}
	.wi__link:hover {
		padding-left: 16px;
	}

	.wi__num {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--accent);
		align-self: start;
		padding-top: 4px;
	}

