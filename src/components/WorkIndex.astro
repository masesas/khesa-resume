---
// Interactive work index (Concept A): a scannable list on the left, a sticky
// preview pane on the right that swaps the hero shot as you hover each row.
// Featured projects get a larger row. On touch / narrow screens the preview
// pane is hidden and each row shows an inline thumbnail instead.
import BrowserFrame from "./frames/BrowserFrame.astro";
import PhoneFrame from "./frames/PhoneFrame.astro";
import type { Project } from "../data/projects";

interface Props {
	projects: Project[];
}
const { projects } = Astro.props;

// Order featured first so the index reads strongest-first.
const ordered = [...projects].sort(
	(a, b) => Number(Boolean(b.featured)) - Number(Boolean(a.featured)),
);

// Map a tech token (from project.tech, " · "-separated) to a public/tech/*.svg
// icon name. `mono` icons are dark-on-transparent and need a fill in CSS.
type IconDef = { name: string; mono?: boolean };
const TECH_ICON: Record<string, IconDef> = {
	vue: { name: "vuejs" },
	node: { name: "nodejs" },
	"node.js": { name: "nodejs" },
	express: { name: "express", mono: true },
	postgresql: { name: "postgresql" },
  mysql: { name: "mysql" },
	react: { name: "react" },
	java: { name: "java" },
	springboot: { name: "spring" },
	"spring boot": { name: "spring" },
	jpa: { name: "spring" },
	android: { name: "android" },
	kotlin: { name: "kotlin" },
	laravel: { name: "laravel" },
	flutter: { name: "flutter" },
	ios: { name: "apple", mono: true },
	firebase: { name: "firebase" },
	"c#": { name: "csharp" },
	".net": { name: "dotnetcore" },
	"sql server": { name: "microsoftsqlserver" },
	swift: { name: "swift" },
  javascript: { name: "javascript" },
  php: { name: "php" },
  gmaps: { name: "gmaps" },
  bluetooth: { name: "bluetooth" },
  redis: { name: "redis" },
};
// Generic tokens we never iconize — silently skipped.
const TECH_SKIP = new Set([
	"web",
	"mobile",
	"mobile game",
	"financing platform",
	"music aggregator",
	"workshop management",
	"sprint & project tracking",
	"syllable learning for kids",
	"asset appraisal",
	"google maps api",
]);

type TechIcon = { name: string; label: string; mono: boolean };
function techIcons(tech?: string): TechIcon[] {
	if (!tech) return [];
	const out: TechIcon[] = [];
	const seen = new Set<string>();
	for (const raw of tech.split("·")) {
		const label = raw.trim();
		const key = label.toLowerCase();
		if (TECH_SKIP.has(key)) continue;
		const def = TECH_ICON[key];
		if (!def || seen.has(def.name)) continue;
		seen.add(def.name);
		out.push({ name: def.name, label, mono: Boolean(def.mono) });
	}
	return out;
}

const hero = (p: Project) => p.shots[0];
---

<div class="wi">
	<ol class="wi__list">
		{
			ordered.map((p, i) => {
				const h = hero(p);
				const Tag = p.url ? "a" : "div";
				const href = p.url ? `https://${p.url}` : undefined;
				return (
					<li
						class={`wi__row${p.featured ? " wi__row--featured" : ""}`}
						data-reveal
					>
						<Tag
							class="wi__link"
							data-slug={p.slug}
							data-active={i === 0 ? "true" : "false"}
						>
							<span class="wi__main">
								<span class="wi__title">{p.title}</span>
								{/* {p.impact && (
									<span class="wi__impact">
										{p.impact}
									</span>
								)} */}
							</span>

							{/* Inline thumb — only shows on touch / narrow screens. */}
							<span class="wi__thumb" aria-hidden="true">
								<img
									src={h.src}
									alt=""
									loading="lazy"
								/>
							</span>

							<span class="wi__meta">
								{p.platforms && (
									<span class="wi__platforms">
										{p.platforms.map((pl) => (
											<span class="wi__badge">
												{pl}
											</span>
										))}
									</span>
								)}
								{/* {p.year && <span class="wi__year">{p.year}</span>} */}
							</span>
						</Tag>
					</li>
				);
			})
		}
	</ol>

	<div class="wi__preview" aria-hidden="true">
		<div class="wi__preview-inner">
			{
				ordered.map((p, i) => {
					const icons = techIcons(p.tech);
					return (
						<figure
							class="wi__figure"
							data-preview={p.slug}
							data-active={i === 0 ? "true" : "false"}
						>
							<div class="wi__wrapper">
								<span class="wi__caption-role">
									{p.title}
								</span>
								<div class="wi__wrapper-sub">
									{(p.storeListing || p.url) && (
										<div class="wi__wrapper-col">
											<span class="wi__lable-thin">
												Available on
											</span>
											<div class="wi__wrapper-info">
												{p.url && (
													<a
														href={
															p.url
														}
														target="_blank"
														rel="noopener"
													>
														🌐
													</a>
												)}
												{p.storeListing
													?.android && (
													<a
														href={
															p
																.storeListing
																.android
														}
														target="_blank"
														rel="noopener"
													>
														<img
															class={`wi__caption-icon}`}
															src={`/tech/playstore.png`}
															alt={
																"Google Play Store"
															}
															title={
																"Google Play Store"
															}
															width="20"
															height="20"
															loading="lazy"
														/>
													</a>
												)}
												{p.storeListing
													?.ios && (
													<a
														href={
															p
																.storeListing
																.ios
														}
														target="_blank"
														rel="noopener"
													>
														<img
															class={`wi__caption-icon}`}
															src={`/tech/appstore.png`}
															alt={
																"App Store"
															}
															title={
																"App Store"
															}
															width="20"
															height="20"
															loading="lazy"
														/>
													</a>
												)}
											</div>
										</div>
									)}
									{(p.storeListing || p.url) && (
										<span class="wi__seperator" />
									)}
									<div class="wi__wrapper-col">
										<span class="wi__lable-thin">
											Tech
										</span>
										<figcaption class="wi__caption">
											{icons.length > 0 && (
												<span class="wi__caption-icons">
													{icons.map(
														(t) => (
															<img
																class={`wi__caption-icon${t.mono ? " wi__caption-icon--mono" : ""}`}
																src={`/tech/${t.name}.svg`}
																alt={
																	t.label
																}
																title={
																	t.label
																}
																width="20"
																height="20"
																loading="lazy"
															/>
														),
													)}
												</span>
											)}
										</figcaption>
									</div>
								</div>
							</div>
							<div
								class="wi__carousel"
								data-carousel
								data-index="0"
							>
								<div class="wi__viewport">
									<div class="wi__track">
										{p.shots.map((shot, si) => (
											<div
												class="wi__slide"
												data-slide={si}
											>
												{shot.type ===
												"web" ? (
													<BrowserFrame>
														<img
															src={
																shot.src
															}
															alt={
																shot.alt
															}
															loading="lazy"
														/>
													</BrowserFrame>
												) : (
													<PhoneFrame>
														<img
															src={
																shot.src
															}
															alt={
																shot.alt
															}
															loading="lazy"
														/>
													</PhoneFrame>
												)}
											</div>
										))}
									</div>
								</div>

								{p.shots.length > 1 && (
									<div class="wi__controls">
										<button
											class="wi__arrow"
											data-prev
											type="button"
											aria-label="Previous image"
										>
											←
										</button>
										<div class="wi__dots">
											{p.shots.map((_, di) => (
												<button
													class="wi__dot"
													data-dot={di}
													data-active={
														di === 0
															? "true"
															: "false"
													}
													type="button"
													aria-label={`Go to image ${di + 1}`}
												/>
											))}
										</div>
										<button
											class="wi__arrow"
											data-next
											type="button"
											aria-label="Next image"
										>
											→
										</button>
									</div>
								)}
							</div>
						</figure>
					);
				})
			}
		</div>
	</div>
</div>

<style>
	.wi {
		display: grid;
		grid-template-columns: 1.05fr 0.95fr;
		gap: clamp(32px, 5vw, 72px);
		align-items: center;
	}

	/* ---------- List ---------- */
	.wi__list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.wi__row {
		border-top: 1px solid var(--line-soft);
	}
	.wi__row:last-child {
		border-bottom: 1px solid var(--line-soft);
