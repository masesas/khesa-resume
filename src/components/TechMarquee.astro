---
// Two-row infinite marquee of tech-stack icons, scrolling in opposite
// directions. Icons live in public/tech/<name>.svg. The track is duplicated so
// the CSS translate loop is seamless. Pauses on hover; respects reduced-motion.
import { techMarquee } from '../data/resume';

const mid = Math.ceil(techMarquee.length / 2);
const rowA = techMarquee.slice(0, mid);
const rowB = techMarquee.slice(mid);
---

<div class="marquee" aria-hidden="true">
  <div class="marquee__row">
    <div class="marquee__track marquee__track--left">
      {[...rowA, ...rowA].map((t) => (
        <span class="chip">
          <img
            class={`chip__icon${t.mono ? ' chip__icon--mono' : ''}`}
            src={`/tech/${t.name}.svg`}
            alt=""
            width="22"
            height="22"
            loading="lazy"
          />
          <span class="chip__label">{t.label}</span>
        </span>
      ))}
    </div>
  </div>
  <div class="marquee__row">
    <div class="marquee__track marquee__track--right">
      {[...rowB, ...rowB].map((t) => (
        <span class="chip">
          <img
            class={`chip__icon${t.mono ? ' chip__icon--mono' : ''}`}
            src={`/tech/${t.name}.svg`}
            alt=""
            width="22"
            height="22"
            loading="lazy"
          />
          <span class="chip__label">{t.label}</span>
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .marquee {
    display: flex;
    flex-direction: column;
    gap: 14px;
    overflow: hidden;
    /* Fade the edges so chips dissolve instead of hard-cutting. */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
  }
  .marquee__row {
    display: flex;
    overflow: hidden;
  }
  .marquee__track {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
    width: max-content;
    will-change: transform;
  }
  .marquee__track--left {
    animation: scroll-left 46s linear infinite;
  }
  .marquee__track--right {
    animation: scroll-right 52s linear infinite;
  }
  .marquee:hover .marquee__track {
    animation-play-state: paused;
  }

  @keyframes scroll-left {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @keyframes scroll-right {
    from { transform: translateX(-50%); }
    to { transform: translateX(0); }
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 9px 16px 9px 13px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--bg-elev);
    white-space: nowrap;
    flex-shrink: 0;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }
  .chip:hover {
    border-color: color-mix(in srgb, var(--fg) 28%, transparent);
    transform: translateY(-2px);
  }
  .chip__icon {
    width: 22px;
    height: 22px;
    display: block;
    /* Slightly muted until hovered, so the row reads as texture not noise. */
    opacity: 0.92;
  }
  .chip__icon--mono {
    /* simple-icons are black; invert to near-white for the dark theme. */
    filter: invert(96%);
  }
  .chip__label {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
    }
    /* Without motion, show the first row statically and let it wrap. */
    .marquee__row {
      overflow-x: auto;
    }
  }
</style>
