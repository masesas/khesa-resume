---
import Preloader from '../components/Preloader.astro';
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';

interface Props {
  title?: string;
}
const { title = 'Khesa — Portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#080d2c" />
    <title>{title}</title>
  </head>
  <body>
    <!-- <Preloader /> -->
    <slot />

    <script>
      import { initPreloader } from '../scripts/preloader';
      import { initReveal } from '../scripts/reveal';
      import { initSmoothScroll } from '../scripts/smooth-scroll';
      import { initCounters } from '../scripts/counters';
      import { initMagnetic } from '../scripts/magnetic';

      // Preloader runs first, then unlocks the rest on completion.
      initPreloader(() => {
        initReveal();
        initSmoothScroll();
        initCounters();
        initMagnetic();
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Lucien-inspired deep-navy dark theme. */
    --bg: #080d2c;
    --bg-elev: #0d1438;
    --bg-card: #0f1740;
    --fg: #ffffff;
    --muted: #8a93b8;
    --line: rgba(255, 255, 255, 0.1);
    --line-soft: rgba(255, 255, 255, 0.06);
    --accent: #5c9cff;
    --accent-glow: rgba(92, 156, 255, 0.35);
    --maxw: 1180px;

    --font-display: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-sans: 'Space Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI',
      Roboto, sans-serif;
    --font-mono: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;

    font-family: var(--font-sans);
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
  }
  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }
  /* Lock scroll while the preloader is on screen. */
  body.is-loading {
    overflow: hidden;
    height: 100vh;
  }

  a {
    color: inherit;
  }

  img {
    max-width: 100%;
  }

  /* Subtle ambient glow fixed behind content (Lucien atmosphere). */
  body::before {
    content: '';
    position: fixed;
    top: -10%;
    left: 50%;
    width: 90vw;
    max-width: 1100px;
    height: 600px;
    transform: translateX(-50%);
    background: radial-gradient(
      ellipse at center,
      rgba(92, 156, 255, 0.1),
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* Smooth scroll (Lenis). */
  html.lenis,
  html.lenis body {
    height: auto;
  }
  .lenis.lenis-smooth {
    scroll-behavior: auto !important;
  }
  .lenis.lenis-stopped {
    overflow: hidden;
  }

  .container {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 1;
  }

  /* Scroll reveal — CSS owns the transition; reveal.ts toggles .is-in. */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }
  [data-reveal].is-in {
    opacity: 1;
    transform: none;
  }

  [data-reveal-stagger] > * {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: calc(var(--i, 0) * 70ms);
  }
  [data-reveal-stagger].is-in > * {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-reveal-stagger] > * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>
