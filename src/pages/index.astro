<script>
	// Hero choreography: stagger the intro chars, mask-reveal the title lines,
	// then cycle the accent word. All gated by reduced-motion (CSS shows the
	// static state; JS simply skips the word cycling).
	const reduce = window.matchMedia(
		"(prefers-reduced-motion: reduce)",
	).matches;

	// Index intro chars so CSS can stagger them via --ci.
	const intro = document.querySelector<HTMLElement>("[data-hero-intro]");
	if (intro) {
		intro.querySelectorAll<HTMLElement>(".hero__char").forEach((c, i) =>
			c.style.setProperty("--ci", String(i)),
		);
	}

	// Trigger the reveal on next frame so the transitions actually play.
	const title = document.querySelector<HTMLElement>(".hero__title");
	requestAnimationFrame(() => {
		requestAnimationFrame(() => {
			intro?.classList.add("is-in");
			title?.classList.add("is-in");
		});
	});

	// Cycle the accent word.
	const cycle = document.querySelector<HTMLElement>("[data-hero-cycle]");
	if (cycle && !reduce) {
		const words = Array.from(
			cycle.querySelectorAll<HTMLElement>(".hero__cycle-word"),
		);
		let current = 0;
		const CYCLE_MS = 2400;
		setInterval(() => {
			const prev = words[current];
			current = (current + 1) % words.length;
			const next = words[current];
			prev.classList.remove("is-active");
			prev.classList.add("is-out");
			next.classList.remove("is-out");
			next.classList.add("is-active");
			// Clear the "out" state after its transition so it can re-enter later.
			window.setTimeout(() => prev.classList.remove("is-out"), 500);
		}, CYCLE_MS);
	}

	const actionFloat = document.querySelector(".action__float");
	if (actionFloat) {
		actionFloat.addEventListener("click", () => {
			actionFloat.querySelector(".action__expanded")?.classList.toggle("action__expanded-show");
		});

	}
</script>
