---
import Base from "../layouts/Base.astro";
import WorkIndex from "../components/WorkIndex.astro";
import TechMarquee from "../components/TechMarquee.astro";
import { projects } from "../data/projects";
import { profile, stats, experience, techMarquee } from "../data/resume";

const year = new Date().getFullYear();
---

<Base title={`${profile.name} — ${profile.role}`}>
	<main id="top">
		<!-- HERO -->
		<section class="hero container">
			<h1 class="hero__title">
				<span class="hero__line"
					><span class="hero__line-inner"
						>Hi, I'm Khesa <br />I build systems</span
					></span
				>
				<span class="hero__line">
					<span class="hero__line-inner">
						that&nbsp;<span
							class="hero__cycle"
							data-hero-cycle
							aria-hidden="true"
						>
							<span class="hero__cycle-word is-active"
								>ship<span class="hero__cycle-dot"
									>.</span
								></span
							>
							<span class="hero__cycle-word"
								>scale<span class="hero__cycle-dot"
									>.</span
								></span
							>
							<span class="hero__cycle-word"
								>last<span class="hero__cycle-dot"
									>.</span
								></span
							>
							<span class="hero__cycle-word"
								>endure<span class="hero__cycle-dot"
									>.</span
								></span
							>
						</span>
					</span>
				</span>
				<span class="sr-only"
					>I build systems that ship, scale, last, and endure.</span
				>
			</h1>
			<!-- <p class="hero__tagline" data-reveal>{profile.tagline}</p> -->
			<div class="hero__links" data-reveal>
				<a
					href={`mailto:${profile.email}`}
					class="btn btn--primary"
					data-magnetic="0.3">Get in touch</a
				>
				<a
					href={profile.githubUrl}
					target="_blank"
					rel="noopener"
					class="btn"
					data-magnetic="0.3">GitHub ↗</a
				>
				<a
					href={profile.linkedinUrl}
					target="_blank"
					rel="noopener"
					class="btn"
					data-magnetic="0.3">LinkedIn ↗</a
				>
			</div>
		</section>

		<!-- TECH MARQUEE -->
		<div class="marquee-wrap">
			<TechMarquee />
		</div>

		<!-- ABOUT + STATS -->
		<section id="about" class="section container">
			<div class="section__head" data-reveal>
				<h2 class="section__title">
					Reliable systems, shipped not just demoed
				</h2>
			</div>
			<p class="about__lead" data-reveal>{profile.summary}</p>
			<div class="stats" data-reveal-stagger>
				{
					stats.map((s) => (
						<div class="stat glow-tile">
							<span
								class="stat__value"
								data-count={s.value}
								data-suffix={s.suffix}
							>
								0{s.suffix}
							</span>
							<span class="stat__label">{s.label}</span>
						</div>
					))
				}
			</div>
		</section>

		<!-- EXPERIENCE -->
		<section id="experience" class="section container">
			<div class="section__head" data-reveal>
				<h2 class="section__title">
					Where I've built &amp; shipped
				</h2>
			</div>
			<ol class="timeline">
				{
					experience.map((job) => (
						<li class="job" data-reveal>
							<div class="job__period">
								{job.period}
								{job.current && (
									<span class="job__now">Now</span>
								)}
							</div>
							<div class="job__body">
								<h3 class="job__role">{job.role}</h3>
								<p class="job__company">
									{job.company}
								</p>
								<ul class="job__points">
									{job.highlights.map((h) => (
										<li>{h}</li>
									))}
								</ul>
								<div class="job__tech">
									{job.tech.map((t) => (
										<span class="tag">{t}</span>
									))}
								</div>
							</div>
						</li>
					))
				}
			</ol>
		</section>

		<!-- WORK / GALLERY -->
		<section id="work" class="section container">
			<div class="section__head" data-reveal>
				<h2 class="section__title">Building Products End-to-End</h2>
			</div>
			<WorkIndex projects={projects} />
		</section>
	</main>

	<!-- CONTACT / FOOTER -->
	<footer id="contact" class="footer">
		<div class="container footer__inner">
			<h2 class="footer__headline" data-reveal>
				Deploy with certainty.<br />Let's build something that
				lasts.
			</h2>
			<!-- <a
				class="footer__mail"
				href={`mailto:${profile.email}`}
				data-magnetic="0.2">{profile.email}</a
			> -->
			<div class="footer__grid" data-reveal-stagger>
				<a
					href={profile.githubUrl}
					target="_blank"
					rel="noopener"
					class="glow-tile"
				>
					<span class="footer__k">GitHub</span><span
						class="footer__v">@{profile.github} ↗</span
					>
				</a>
				<a
					href={profile.linkedinUrl}
					target="_blank"
					rel="noopener"
					class="glow-tile"
				>
					<span class="footer__k">LinkedIn</span><span
						class="footer__v">{profile.linkedin} ↗</span
					>
				</a>
				<!-- <a
					href={`tel:${profile.phone.replace(/\s/g, "")}`}
					class="glow-tile"
				>
					<span class="footer__k">Phone</span><span
						class="footer__v">{profile.phone}</span
					>
				</a> -->
				<div class="glow-tile">
					<span class="footer__k">Location</span><span
						class="footer__v">{profile.location}</span
					>
				</div>
			</div>
			<p class="footer__meta">
				© {year}
				{profile.name} — built with Astro.
			</p>
		</div>
	</footer>

	<div class="action__float">
		<span>Contact Me</span>
		<div class="action__expanded">
			<a
				href={`${profile.wa}`}
				target="_blank"
				rel="noopener"
				class="wa__link"
			>
				<img
					src={`/tech/wa.svg`}
					alt={"WhatsApp"}
					title={"WhatsApp"}
					width="50"
					height="50"
					loading="lazy"
				/>
			</a>
			<a
				href={`mailto:${profile.email}`}
				target="_blank"
				rel="noopener"
				class="wa__link"
			>
				<img
					src={`/tech/email.svg`}
					alt={"Email"}
					title={"Email"}
					width="50"
					height="50"
					loading="lazy"
				/>
			</a>
		</div>
	</div>
</Base>

<style>
	/* ---------- Sticky header ---------- */
	.topbar {
		position: sticky;
		top: 0;
		z-index: 50;
		backdrop-filter: saturate(160%) blur(16px);
		background: color-mix(in srgb, var(--bg) 72%, transparent);
		border-bottom: 1px solid var(--line-soft);
	}
	.topbar__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
	}
	.topbar__name {
		font-family: var(--font-mono);
		font-weight: 500;
		font-size: 16px;
		letter-spacing: 0.18em;
		text-decoration: none;
	}
	.topbar__nav {
		display: flex;
		align-items: center;
		gap: 28px;
		font-size: 14px;
	}
	.topbar__nav > a:not(.topbar__cta) {
		text-decoration: none;
		color: var(--muted);
		transition: color 0.2s ease;
	}
	.topbar__nav > a:not(.topbar__cta):hover {
		color: var(--fg);
	}
	.topbar__cta {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 16px;
		border: 1px solid var(--line);
		border-radius: 999px;
		text-decoration: none;
		color: var(--fg);
		font-size: 13px;
		will-change: transform;
		transition:
			transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
			border-color 0.2s ease,
			background 0.2s ease;
	}
	.topbar__cta:hover {
		border-color: color-mix(in srgb, var(--accent) 50%, transparent);
		background: color-mix(in srgb, var(--accent) 12%, transparent);
	}
	.topbar__status {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #4ade80;
		box-shadow: 0 0 8px #4ade80;
		animation: pulse 2.4s ease-out infinite;
	}
	@keyframes pulse {
		0% {
			box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.5);
		}
		70% {
			box-shadow: 0 0 0 7px rgba(74, 222, 128, 0);
		}
		100% {
			box-shadow: 0 0 0 0 rgba(74, 222, 128, 0);
		}
	}
	@media (max-width: 640px) {
		.topbar__nav > a[href="#about"],
		.topbar__nav > a[href="#experience"] {
			display: none;
		}
	}

	/* ---------- Shared section chrome (Lucien: centered) ---------- */
	.section {
		padding-top: clamp(80px, 12vw, 160px);
	}
	.section__head {
		text-align: center;
		max-width: 760px;
		margin: 0 auto clamp(44px, 6vw, 72px);
	}
	.section__tag {
		display: inline-block;
		font-family: var(--font-mono);
		font-size: 13px;
		letter-spacing: 0.05em;
		color: var(--accent);
		margin-bottom: 18px;
	}
	.section__num {
		color: var(--muted);
	}
	.section__title {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(28px, 4.5vw, 52px);
		line-height: 1.08;
		letter-spacing: -0.02em;
	}
	.section__note {
		margin: 18px auto 0;
		font-size: 15px;
		color: var(--muted);
		max-width: 480px;
	}

	/* ---------- Shared glow tile (Lucien card) ---------- */
	.glow-tile {
		position: relative;
		background: linear-gradient(
			180deg,
			var(--bg-card),
			color-mix(in srgb, var(--bg-card) 65%, var(--bg))
		);
		border: 1px solid var(--line);
		border-radius: 14px;
		transition:
			border-color 0.35s ease,
			transform 0.35s ease,
			box-shadow 0.35s ease;
	}
	.glow-tile:hover {
		border-color: color-mix(in srgb, var(--accent) 38%, transparent);
		transform: translateY(-3px);
		box-shadow: 0 18px 44px rgba(0, 0, 0, 0.35);
	}

	/* ---------- Buttons ---------- */
	.btn {
		display: inline-flex;
		align-items: center;
		padding: 12px 22px;
		border: 1px solid var(--line);
		border-radius: 999px;
		text-decoration: none;
		color: var(--fg);
		font-size: 15px;
		will-change: transform;
		transition:
			transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
			border-color 0.2s ease,
			background 0.2s ease;
	}
	.btn:hover {
		border-color: color-mix(in srgb, var(--accent) 45%, transparent);
	}
	.btn--primary {
		background: var(--accent);
		border-color: var(--accent);
		color: #06122e;
		font-weight: 500;
		box-shadow: 0 8px 28px var(--accent-glow);
	}
	.btn--primary:hover {
		background: color-mix(in srgb, var(--accent) 88%, white);
	}

	/* ---------- Hero (centered) ---------- */
	.hero {
		padding-top: clamp(72px, 13vw, 150px);
		padding-bottom: clamp(40px, 6vw, 64px);
		text-align: center;
	}
	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin: 0 0 30px;
		font-family: var(--font-mono);
		font-size: 13px;
		letter-spacing: 0.06em;
		color: var(--muted);
	}
	.eyebrow__mark {
		color: var(--accent);
	}

	/* ---------- Hero intro: char blur-in ---------- */
	.hero__intro {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		margin: 0 0 26px;
		font-family: var(--font-mono);
		font-size: 13px;
		letter-spacing: 0.06em;
		color: var(--muted);
	}
	.hero__intro-mark {
		color: var(--accent);
		margin-right: 10px;
	}
	.hero__char {
		display: inline-block;
		white-space: pre;
		opacity: 0;
		filter: blur(8px);
		transform: translateY(6px);
		transition:
			opacity 0.5s ease,
			filter 0.5s ease,
			transform 0.5s ease;
		transition-delay: calc(var(--ci, 0) * 38ms);
	}
	.hero__intro.is-in .hero__char {
		opacity: 1;
		filter: blur(0);
		transform: none;
	}

	/* ---------- Hero title: mask reveal per line ---------- */
	.hero__title {
		margin: 0 auto;
		max-width: 15ch;
		font-family: var(--font-display);
		font-size: clamp(44px, 9vw, 108px);
		line-height: 1.02;
		font-weight: 300;
		letter-spacing: -0.035em;
	}
	.hero__line {
		display: block;
		overflow: hidden; /* mask: hides the inner span before it slides up */
	}
	.hero__line-inner {
		display: inline-block;
		transform: translateY(110%);
		transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
	}
	.hero__line:nth-child(2) .hero__line-inner {
		transition-delay: 0.12s;
	}
	.hero__title.is-in .hero__line-inner {
		transform: none;
	}

	/* ---------- Cycling accent word + shimmer ---------- */
	.hero__cycle {
		position: relative;
		display: inline-grid; /* stack words; width follows the active one */
		vertical-align: baseline;
		font-style: italic;
	}
	.hero__cycle-word {
		grid-area: 1 / 1;
		font-style: italic;
		background: linear-gradient(
			100deg,
			var(--accent) 30%,
			#a9c8ff 50%,
			var(--accent) 70%
		);
		background-size: 200% auto;
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		opacity: 0;
		transform: translateY(0.5em) rotateX(-40deg);
		transform-origin: bottom;
		transition:
			opacity 0.45s ease,
			transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
		animation: shimmer 5s linear infinite;
	}
	.hero__cycle-word.is-active {
		opacity: 1;
		transform: none;
	}
	.hero__cycle-word.is-out {
		opacity: 0;
		transform: translateY(-0.5em) rotateX(40deg);
	}
	.hero__cycle-word {
		justify-self: start; /* dot hugs each word, no trailing gap */
	}
	.hero__cycle-dot {
		-webkit-text-fill-color: var(--accent);
		color: var(--accent);
	}
	@keyframes shimmer {
		to {
			background-position: -200% center;
		}
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	/* Reduced motion: show everything statically, no transforms/animation. */
	@media (prefers-reduced-motion: reduce) {
		.hero__char,
		.hero__line-inner,
		.hero__cycle-word {
			opacity: 1 !important;
			filter: none !important;
			transform: none !important;
			transition: none !important;
			animation: none !important;
		}
		.hero__cycle-word:not(.is-active) {
			display: none;
		}
	}
	.hero__tagline {
		margin: clamp(28px, 4vw, 40px) auto 0;
		font-size: clamp(15px, 1.6vw, 18px);
		line-height: 1.6;
		color: var(--muted);
		max-width: 600px;
	}
	.hero__links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 14px;
		margin-top: clamp(32px, 4vw, 44px);
	}

	/* ---------- Marquee wrap ---------- */
	.marquee-wrap {
		padding: clamp(24px, 4vw, 44px) 0;
		border-top: 1px solid var(--line-soft);
		border-bottom: 1px solid var(--line-soft);
		margin-top: clamp(28px, 4vw, 52px);
	}

	/* ---------- About + stats ---------- */
	.about__lead {
		text-align: center;
		max-width: 820px;
		margin: 0 auto;
		font-family: var(--font-display);
		font-weight: 300;
		font-size: clamp(20px, 2.6vw, 30px);
		line-height: 1.5;
		letter-spacing: -0.015em;
	}
	.stats {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 18px;
		margin-top: clamp(48px, 6vw, 72px);
	}
	.stat {
		display: flex;
		flex-direction: column;
		gap: 8px;
		padding: 28px 24px;
		text-align: center;
		align-items: center;
	}
	.stat__value {
		font-family: var(--font-display);
		font-size: clamp(34px, 5vw, 56px);
		font-weight: 300;
		letter-spacing: -0.03em;
		line-height: 1;
		color: var(--accent);
		font-variant-numeric: tabular-nums;
	}
	.stat__label {
		font-size: 13px;
		color: var(--muted);
		line-height: 1.35;
	}
	@media (max-width: 760px) {
		.stats {
			grid-template-columns: 1fr 1fr;
		}
	}

	/* ---------- Stack (icon-only, borderless) ---------- */
	.stack {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(96px, 1fr));
		gap: clamp(20px, 3vw, 36px) 12px;
		max-width: 880px;
		margin: 0 auto;
	}
	.stack__item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 12px;
		text-align: center;
	}
	.stack__icon {
		width: 40px;
		height: 40px;
		display: block;
		opacity: 0.78;
		filter: grayscale(0.25);
		transition:
			opacity 0.3s ease,
			transform 0.3s ease,
			filter 0.3s ease;
	}
	.stack__icon--mono {
		/* simple-icons are black; invert to near-white for the dark theme. */
		filter: invert(96%);
		opacity: 0.7;
	}
	.stack__item:hover .stack__icon {
		opacity: 1;
		filter: grayscale(0);
		transform: translateY(-4px) scale(1.08);
	}
	.stack__item:hover .stack__icon--mono {
		filter: invert(100%);
		opacity: 1;
	}
	.stack__label {
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.01em;
		color: var(--muted);
		transition: color 0.3s ease;
	}
	.stack__item:hover .stack__label {
		color: var(--fg);
	}

	/* ---------- Experience timeline ---------- */
	.timeline {
		list-style: none;
		margin: 0 auto;
		padding: 0;
		max-width: 920px;
	}
	.job {
		display: grid;
		grid-template-columns: 190px 1fr;
		gap: 36px;
		padding: 34px 0;
		border-top: 1px solid var(--line-soft);
	}
	.job:last-child {
		border-bottom: 1px solid var(--line-soft);
	}
	.job__period {
		font-family: var(--font-mono);
		font-size: 13px;
		color: var(--muted);
		display: flex;
		align-items: center;
		gap: 10px;
		flex-wrap: wrap;
		padding-top: 5px;
	}
	.job__now {
		font-family: var(--font-mono);
		font-size: 11px;
		color: #4ade80;
		background: rgba(74, 222, 128, 0.12);
		border: 1px solid rgba(74, 222, 128, 0.3);
		padding: 2px 8px;
		border-radius: 999px;
	}
	.job__role {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(19px, 2.4vw, 25px);
		font-weight: 400;
		letter-spacing: -0.01em;
	}
	.job__company {
		margin: 5px 0 16px;
		font-size: 14px;
		color: var(--accent);
		font-family: var(--font-mono);
	}
	.job__points {
		margin: 0 0 18px;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.job__points li {
		position: relative;
		padding-left: 22px;
		font-size: 15px;
		line-height: 1.55;
		color: #c4cae0;
	}
	.job__points li::before {
		content: "";
		position: absolute;
		left: 2px;
		top: 9px;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 8px var(--accent-glow);
	}
	.job__tech {
		display: flex;
		flex-wrap: wrap;
		gap: 7px;
	}
	.tag {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--muted);
		padding: 3px 10px;
		border: 1px solid var(--line-soft);
		border-radius: 6px;
	}
	@media (max-width: 680px) {
		.job {
			grid-template-columns: 1fr;
			gap: 14px;
		}
	}

	/* ---------- Footer / contact ---------- */
	.footer {
		margin-top: clamp(80px, 12vw, 150px);
		border-top: 1px solid var(--line-soft);
		background: linear-gradient(
			180deg,
			transparent,
			rgba(92, 156, 255, 0.05)
		);
